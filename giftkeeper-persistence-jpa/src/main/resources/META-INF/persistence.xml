<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
  <persistence-unit name="giftkeeper-pu" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>com.giftkeeper.persistence.jpa.JpaPersonEntity</class>
    <class>com.giftkeeper.persistence.jpa.JpaOccasionEntity</class>
    <class>com.giftkeeper.persistence.jpa.JpaGiftIdeaEntity</class>
    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/giftkeeper"/>
      <property name="jakarta.persistence.jdbc.user" value="giftkeeper"/>
      <property name="jakarta.persistence.jdbc.password" value="giftkeeper"/>
      <property name="hibernate.hbm2ddl.auto" value="update"/>
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
